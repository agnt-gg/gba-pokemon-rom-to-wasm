# Dependencies
node_modules/

# Build artifacts and generated files
build/*.ppm
build/*.png
build/*.wav
build/*.wasm
build/*.wat
*.map

# Copyrighted ROMs and saves must never be committed.
# We lift from public ARM7TDMI/GBATEK conventions, NOT from user ROM bytes.
*.gba
*.gb
*.gbc
*.sav
*.sgm
*.ss*
*.state
build/*.gba
build/*.gb

# EXCEPTION: jsmolka/gba-tests conformance ROMs are MIT-licensed (not commercial ROMs),
# so we keep them committed to make the CPU suite reproducible.
!build/arm.gba
!build/thumb.gba

# Browser/profile/user-state extraction scratch
brave-live-ruby.sav
extracted-brave-*.sav
tmp-brave-leveldb/
agent/browser-*.mjs
agent/extract-save-browser.mjs
agent/extract-save-level*.ts
agent/repro-from-live-save.ts

# Investigation scratch scripts that are useful locally but not part of the public package
agent/catch-ewram-jump.ts
agent/continue-save-probe.ts
agent/decode-caller-final.ts
agent/disasm-crash-callee.ts
agent/trace-callee-calls.ts

# Logs / scratch
*.log
err.txt
server.log
tmp_*
*_tmp.*

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local dev archive of the pre-consolidation git history
.git-localdev-archive/

# Downloaded reference sources (pret decomps) used during debugging
build/*.c
build/*.s
!build/arm.gba
!build/thumb.gba

# One-shot local session scripts (applied + documented in commit messages)
tools/_patch_*
tools/_skill_*
tools/_fix_*
tools/_tree_diff.cjs

